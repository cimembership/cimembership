#--------------------------------------------------------------------
# Environment Configuration
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# Application Configuration
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'
app.timezone = 'UTC'
app.CSPEnabled = false

#--------------------------------------------------------------------
# Database Configuration
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = cimembership
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix = ci_
database.default.port = 3306

#--------------------------------------------------------------------
# Security
#--------------------------------------------------------------------

security.tokenName = csrf_token
security.cookieName = csrf_cookie
security.samesite = Lax

#--------------------------------------------------------------------
# Session
#--------------------------------------------------------------------

session.driver = CodeIgniter\Session\Handlers\DatabaseHandler
session.cookieName = ci_session
session.expiration = 7200
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

#--------------------------------------------------------------------
# Email
#--------------------------------------------------------------------

email.protocol = smtp
email.SMTPHost =
email.SMTPUser =
email.SMTPPass =
email.SMTPPort = 587
email.SMTPCrypto = tls

#--------------------------------------------------------------------
# CIMembership Specific
#--------------------------------------------------------------------

# reCAPTCHA Settings
cimembership.recaptcha.siteKey =
cimembership.recaptcha.secretKey =
cimembership.recaptcha.enabled = false

# OAuth Settings
cimembership.oauth.facebook.enabled = false
cimembership.oauth.facebook.clientId =
cimembership.oauth.facebook.clientSecret =

cimembership.oauth.google.enabled = false
cimembership.oauth.google.clientId =
cimembership.oauth.google.clientSecret =

cimembership.oauth.github.enabled = false
cimembership.oauth.github.clientId =
cimembership.oauth.github.clientSecret =

cimembership.oauth.linkedin.enabled = false
cimembership.oauth.linkedin.clientId =
cimembership.oauth.linkedin.clientSecret =

# General Settings
cimembership.siteName = CIMembership
cimembership.adminEmail = admin@example.com
cimembership.allowRegistration = true
cimembership.requireActivation = false
cimembership.loginAttempts = 5
cimembership.lockoutTime = 900
