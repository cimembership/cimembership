#!/usr/bin/env php
<?php

/**
 * CIMembership v4 - CLI Entry Point
 *
 * This is the command-line entry point for the CodeIgniter framework.
 */

// Check PHP version
if (version_compare(PHP_VERSION, '8.1', '<')) {
    echo "PHP version 8.1 or higher is required. Current version: " . PHP_VERSION . "\n";
    exit(1);
}

// Define root paths FIRST (before any Config classes load)
define('ROOTPATH', realpath(__DIR__) . DIRECTORY_SEPARATOR);
define('FCPATH', ROOTPATH . 'public' . DIRECTORY_SEPARATOR);
define('APPPATH', ROOTPATH . 'app' . DIRECTORY_SEPARATOR);
define('WRITEPATH', ROOTPATH . 'writable' . DIRECTORY_SEPARATOR);
define('SYSTEMPATH', realpath(ROOTPATH . 'vendor/codeigniter4/framework/system') . DIRECTORY_SEPARATOR);
define('COMPOSER_PATH', ROOTPATH . 'vendor/autoload.php');
define('APP_NAMESPACE', 'App');

// Autoloader
require_once ROOTPATH . 'vendor/autoload.php';

// Now that constants are defined, we can load Config classes
require_once APPPATH . 'Config/Paths.php';

// Boot the system
require_once SYSTEMPATH . 'Boot.php';

$paths = new Config\Paths();
exit(CodeIgniter\Boot::bootSpark($paths));
