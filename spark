#!/usr/bin/env php
<?php

/**
 * CIMembership v4 - CLI Entry Point
 *
 * This is the command-line entry point for the CodeIgniter framework.
 */

// Check PHP version
if (version_compare(PHP_VERSION, '8.1', '<')) {
    echo "PHP version 8.1 or higher is required. Current version: " . PHP_VERSION . "\n";
    exit(1);
}

// Define paths
define('ROOTPATH', __DIR__ . DIRECTORY_SEPARATOR);
define('FCPATH', ROOTPATH . 'public' . DIRECTORY_SEPARATOR);
define('WRITEPATH', ROOTPATH . 'writable' . DIRECTORY_SEPARATOR);
define('SYSTEMPATH', realpath(ROOTPATH . 'vendor/codeigniter4/framework/system') . DIRECTORY_SEPARATOR);

// Autoloader
require_once ROOTPATH . 'vendor/autoload.php';

// Load environment
if (is_file(ROOTPATH . '.env')) {
    $dotenv = Dotenv\Dotenv::createImmutable(ROOTPATH);
    $dotenv->load();
}

// Set environment
define('ENVIRONMENT', $_ENV['CI_ENVIRONMENT'] ?? 'development');

// Set default timezone
date_default_timezone_set($_ENV['app.timezone'] ?? 'UTC');

// Error reporting
if (ENVIRONMENT === 'development') {
    error_reporting(-1);
    ini_set('display_errors', '1');
} else {
    error_reporting(E_ALL & ~E_NOTICE & ~E_DEPRECATED & ~E_STRICT);
    ini_set('display_errors', '0');
}

// Run the CLI command
require SYSTEMPATH . 'CLI/Console.php';

$console = new \CodeIgniter\CLI\Console(new \CodeIgniter\CodeIgniter(new \Config\Services()));
$console->run();
